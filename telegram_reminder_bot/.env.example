# Telegram Bot Token (get it from @BotFather)
BOT_TOKEN=your_bot_token_here

# Data directory
# Use an absolute path on VPS to avoid depending on the current working directory.
DATA_DIR=/root/telegram_reminder_bot/data

# Timezone (default: Europe/Moscow)
TIMEZONE=Europe/Moscow

# P2P Sync (optional)
P2P_ENABLED=false
P2P_PORT=8765
P2P_SECRET=your_p2p_secret_here
